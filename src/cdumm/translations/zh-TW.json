  "dialog.verify_error": "\u8cc7\u6599\u5eab\u6216\u904a\u6232\u76ee\u9304\u672a\u8a2d\u5b9a\u3002",
  "dialog.ready_title": "\u5c31\u7dd2",
  "dialog.ready_with_mods_body": "\u904a\u6232\u6a94\u6848\u5df2\u6383\u63cf\uff08{count} \u500b\u6a94\u6848\uff09\u3002\n\n\u60a8\u6709 {mod_count} \u500b\u6a21\u7d44\u9700\u8981\u91cd\u65b0\u532f\u5165\uff1a\n\n{names}\n\n\u5c07\u6bcf\u500b\u6a21\u7d44\u62d6\u653e\u5230\u61c9\u7528\u7a0b\u5f0f\u4e2d\u4ee5\u91cd\u65b0\u532f\u5165\u3002",
  "dialog.ready_no_mods_body": "\u904a\u6232\u6a94\u6848\u5df2\u6383\u63cf\uff08{count} \u500b\u6a94\u6848\uff09\u3002\n\n\u60a8\u73fe\u5728\u53ef\u4ee5\u5c07\u6a21\u7d44\u62d6\u653e\u5230\u61c9\u7528\u7a0b\u5f0f\u4e2d\u4f86\u532f\u5165\u3002",
  "dialog.cdumm_updated_title": "CDUMM \u5df2\u66f4\u65b0",
  "dialog.cdumm_updated_body": "CDUMM \u5df2\u66f4\u65b0\uff0c\u5167\u90e8\u6a21\u7d44\u683c\u5f0f\u5df2\u8b8a\u66f4\u3002\n\n\u60a8\u7684 {count} \u500b\u6a21\u7d44\u9700\u8981\u91cd\u65b0\u532f\u5165\u624d\u80fd\u5728\u65b0\u7248\u672c\u4e2d\n\u6b63\u5e38\u904b\u4f5c\u3002\u9019\u5c07\u9084\u539f\u81f3\u539f\u7248\u4e26\u81ea\u52d5\u91cd\u65b0\u532f\u5165\n\u6240\u6709\u6a21\u7d44\u3002\u60a8\u7684\u6a21\u7d44\u6e05\u55ae\u548c\u8a2d\u5b9a\u5c07\u88ab\u4fdd\u7559\u3002\n\n\u73fe\u5728\u91cd\u65b0\u532f\u5165\uff1f\uff08\u5efa\u8b70\uff09",
  "dialog.mod_list_title": "\u6a21\u7d44\u6e05\u55ae",
  "dialog.mod_list_body": "\u6e05\u55ae\u4e2d\u6709 {total} \u500b\u6a21\u7d44\uff0c{missing} \u500b\u672a\u5b89\u88dd\uff1a\n\n{list}",
  "dialog.critical_update_title": "\u9700\u8981\u91cd\u8981\u66f4\u65b0",
  "dialog.critical_update_body": "\u60a8\u6b63\u5728\u4f7f\u7528 v{version}\uff0c\u8a72\u7248\u672c\u5b58\u5728\u5df2\u77e5\u554f\u984c\uff0c\u53ef\u80fd\u6703\u640d\u58de\u60a8\u7684\u904a\u6232\u3002\n\n\u7248\u672c {tag} \u4fee\u5fa9\u4e86\u9019\u4e9b\u554f\u984c\u3002\n\n\u9ede\u64ca\u300c\u78ba\u5b9a\u300d\u4ee5\u958b\u555f GitHub \u767c\u5e03\u9801\u9762\u4e26\u4e0b\u8f09\u6700\u65b0\u7248\u672c\u3002",
  "dialog.update_available_title": "\u6709\u53ef\u7528\u66f4\u65b0",
  "dialog.update_available_body": "\u6709\u65b0\u7248\u672c\u53ef\u7528\uff1a{tag}\n\n{body}\n\n\u958b\u555f GitHub \u4e0b\u8f09\uff1f",
  "dialog.previous_crash_title": "\u4e0a\u6b21\u5de5\u4f5c\u968e\u6bb5\u7570\u5e38\u7d50\u675f",
