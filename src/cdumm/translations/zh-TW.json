  "dialog.game_scan_needed_title": "\u9700\u8981\u6383\u63cf\u904a\u6232\u6a94\u6848",
  "dialog.game_scan_needed_body": "\u5728\u4f7f\u7528\u6a21\u7d44\u7ba1\u7406\u5668\u4e4b\u524d\uff0c\u9700\u8981\u6383\u63cf\u60a8\u7684\u904a\u6232\u6a94\u6848\u3002\n\n\u70ba\u4e86\u7372\u5f97\u6700\u4f73\u7d50\u679c\uff0c\u8acb\u5148\u900f\u904e Steam \u9a57\u8b49\u60a8\u7684\u904a\u6232\u6a94\u6848\uff1a\n  Steam \u2192 \u53f3\u9375\u9ede\u64ca Crimson Desert \u2192 \u5167\u5bb9\n  \u2192 \u5df2\u5b89\u88dd\u7684\u6a94\u6848 \u2192 \u9a57\u8b49\u904a\u6232\u6a94\u6848\u7684\u5b8c\u6574\u6027\n\n\u60a8\u5df2\u7d93\u9a57\u8b49\u904e\u4e86\u55ce\uff08\u6216\u9019\u662f\u5168\u65b0\u5b89\u88dd\uff09\uff1f",
  "dialog.game_files_changed_title": "\u904a\u6232\u6a94\u6848\u5df2\u8b8a\u66f4",
  "dialog.game_files_changed_body": "\u60a8\u7684\u904a\u6232\u6a94\u6848\u81ea\u4e0a\u6b21\u5feb\u7167\u5f8c\u5df2\u8b8a\u66f4\u3002\n\n\u9019\u901a\u5e38\u8868\u793a\u60a8\u5df2\u900f\u904e Steam \u9a57\u8b49\u3002\n\n\u73fe\u5728\u91cd\u65b0\u6383\u63cf\u4ee5\u66f4\u65b0\u5feb\u7167\uff1f",
  "dialog.fix_game_state_title": "\u4fee\u5fa9\u904a\u6232\u72c0\u614b",
  "dialog.fix_game_state_body": "\u9019\u5c07\u9084\u539f\u6240\u6709\u904a\u6232\u6a94\u6848\u3001\u6e05\u9664\u820a\u5099\u4efd\u3001\n\u79fb\u9664\u5b64\u7acb\u76ee\u9304\uff0c\u4e26\u91cd\u65b0\u532f\u5165\u60a8\u7684\u6a21\u7d44\u3002\n\n\u5982\u679c\u60a8\u5df2\u5148\u900f\u904e Steam \u9a57\u8b49\u904a\u6232\u6a94\u6848\uff0c\n\u5c07\u6703\u540c\u6642\u5efa\u7acb\u65b0\u7684\u5feb\u7167\u3002\n\n\u60a8\u5df2\u900f\u904e Steam \u9a57\u8b49\u4e86\u55ce\uff1f",
  "dialog.old_data_title": "\u767c\u73fe\u820a\u8cc7\u6599",
  "dialog.old_data_body": "\u5728\u4ee5\u4e0b\u4f4d\u7f6e\u767c\u73fe\u820a\u7248 CDUMM \u7684\u6b98\u7559\u8cc7\u6599\uff1a\n{path}\n\uff08{size_mb} MB\uff09\n\n\u81ea v1.7.0 \u8d77\uff0c\u6240\u6709\u6a21\u7d44\u8cc7\u6599\u90fd\u5132\u5b58\u5728\u904a\u6232\u76ee\u9304\u5167\u7684 CDMods \u8cc7\u6599\u593e\u4e2d\u3002\u9019\u4e9b\u820a\u8cc7\u6599\u5df2\u4e0d\u518d\u9700\u8981\u3002\n\n\u522a\u9664\u4ee5\u91cb\u653e\u7a7a\u9593\uff1f",
  "dialog.mods_need_reimport_title": "\u6a21\u7d44\u9700\u8981\u91cd\u65b0\u532f\u5165",
  "dialog.mods_need_reimport_body": "\u9019\u4e9b\u6a21\u7d44\u662f\u5728\u820a\u7248\u672c\u4e0a\u532f\u5165\u7684\uff0c\u4e14\u6c92\u6709\u5132\u5b58\u7684\u4f86\u6e90\u6a94\u6848\u3002\n\u5b83\u5011\u7121\u6cd5\u81ea\u52d5\u66f4\u65b0\u6216\u91cd\u65b0\u8a2d\u5b9a\u3002\n\n{names}\n\n\u8981\u4fee\u6b63\u6b64\u554f\u984c\uff0c\u8acb\u79fb\u9664\u6bcf\u500b\u6a21\u7d44\uff0c\u7136\u5f8c\u5c07\u539f\u59cb\u4e0b\u8f09\u6a94\u6848\n\u91cd\u65b0\u62d6\u653e\u9032\u4f86\u3002\u6bcf\u500b\u6a21\u7d44\u53ea\u9700\u57f7\u884c\u4e00\u6b21\u3002",
  "dialog.game_location_warning_title": "\u904a\u6232\u4f4d\u7f6e\u8b66\u544a",
  "dialog.game_location_warning_body": "\u60a8\u7684\u904a\u6232\u5b89\u88dd\u5728 Program Files \u4e0b\uff0c\u8a72\u4f4d\u7f6e\u5728 Windows \u4e0a\n\u5177\u6709\u53d7\u9650\u7684\u5beb\u5165\u6b0a\u9650\u3002\n\n\u9019\u53ef\u80fd\u6703\u5c0e\u81f4\u6a21\u7d44\u5099\u4efd\u548c\u8a2d\u5b9a\u7684\u554f\u984c\u3002\n\u5982\u679c\u9047\u5230\u554f\u984c\uff0c\u8acb\u8003\u616e\u5c07\u60a8\u7684 Steam\n\u51fd\u5f0f\u5eab\u79fb\u52d5\u5230\u5176\u4ed6\u4f4d\u7f6e\uff08\u4f8b\u5982 C:\\SteamLibrary\uff09\u3002\n\nSteam \u2192 \u8a2d\u5b9a \u2192 \u5132\u5b58\u7a7a\u9593 \u2192 \u65b0\u589e\u51fd\u5f0f\u5eab\u8cc7\u6599\u593e",
  "dialog.vanilla_backup_incomplete_title": "\u539f\u7248\u5099\u4efd\u4e0d\u5b8c\u6574",
  "dialog.vanilla_backup_incomplete_body": "{count} \u500b PAMT \u6a94\u6848\u76ee\u524d\u5df2\u88ab\u4fee\u6539\uff0c\u4e14\u6c92\u6709\u5b8c\u6574\u7684\u539f\u7248\u5099\u4efd\uff1a\n\n{files}\n\n\u8981\u4fee\u6b63\u6b64\u554f\u984c\uff1a\n1. Steam \u2192 \u53f3\u9375\u9ede\u64ca Crimson Desert \u2192 \u5167\u5bb9\n   \u2192 \u5df2\u5b89\u88dd\u7684\u6a94\u6848 \u2192 \u9a57\u8b49\u904a\u6232\u6a94\u6848\u7684\u5b8c\u6574\u6027\n2. \u91cd\u65b0\u555f\u52d5 CDUMM \u2014 \u5b83\u5c07\u5efa\u7acb\u7f3a\u5c11\u7684\u5099\u4efd\n\n\u5728\u6b64\u4e4b\u524d\uff0c\u9084\u539f\u81f3\u539f\u7248\u53ef\u80fd\u7121\u6cd5\u5b8c\u5168\u6062\u5fa9\u9019\u4e9b\u6a94\u6848\u3002",
  "dialog.one_time_reset_title": "CDUMM v{version}",
  "dialog.one_time_reset_body": "\u6b64\u66f4\u65b0\u5305\u542b\u6a21\u7d44\u5132\u5b58\u65b9\u5f0f\u7684\u91cd\u8981\u4fee\u6b63\u3002\n\n\u5728\u7e7c\u7e8c\u4e4b\u524d\uff0c\u8acb\u900f\u904e Steam \u9a57\u8b49\u60a8\u7684\u904a\u6232\u6a94\u6848\uff1a\n\n  Steam \u2192 \u53f3\u9375\u9ede\u64ca Crimson Desert \u2192 \u5167\u5bb9\n  \u2192 \u5df2\u5b89\u88dd\u7684\u6a94\u6848 \u2192 \u9a57\u8b49\u904a\u6232\u6a94\u6848\u7684\u5b8c\u6574\u6027\n\n\u9019\u53ef\u78ba\u4fdd\u60a8\u7684\u904a\u6232\u5728\u91cd\u65b0\u6383\u63cf\u524d\u8655\u65bc\u4e7e\u6de8\u72c0\u614b\u3002",
  "dialog.ready_to_continue_title": "\u6e96\u5099\u597d\u7e7c\u7e8c\u4e86\u55ce\uff1f",
  "dialog.ready_to_continue_body": "\u60a8\u5df2\u900f\u904e Steam \u9a57\u8b49\u904a\u6232\u6a94\u6848\u4e86\u55ce\uff1f",
  "dialog.important_update_title": "CDUMM v{version} \u2014 \u91cd\u8981\u66f4\u65b0",
  "dialog.important_update_body": "\u6b64\u66f4\u65b0\u4fee\u6b63\u4e86\u539f\u7248\u5099\u4efd\u7684\u7ba1\u7406\u65b9\u5f0f\u3002\n\n\u60a8\u73fe\u6709\u7684\u5099\u4efd\u9700\u8981\u5f9e\u982d\u91cd\u5efa\uff0c\u4ee5\u78ba\u4fdd\n\u9084\u539f\u81f3\u539f\u7248\u80fd\u6b63\u5e38\u904b\u4f5c\u3002\n\n\u8acb\u5148\u900f\u904e Steam \u9a57\u8b49\u904a\u6232\u6a94\u6848\uff1a\n\n  Steam \u2192 \u53f3\u9375\u9ede\u64ca Crimson Desert \u2192 \u5167\u5bb9\n  \u2192 \u5df2\u5b89\u88dd\u7684\u6a94\u6848 \u2192 \u9a57\u8b49\u904a\u6232\u6a94\u6848\u7684\u5b8c\u6574\u6027\n\n\u60a8\u7684\u6a21\u7d44\u6e05\u55ae\u5c07\u88ab\u4fdd\u7559 \u2014 \u60a8\u53ea\u9700\u91cd\u65b0\u5957\u7528\u5373\u53ef\u3002",
  "dialog.ready_to_continue_cleanup_body": "\u60a8\u5df2\u900f\u904e Steam \u9a57\u8b49\u904a\u6232\u6a94\u6848\u4e86\u55ce\uff1f\n\n\u9ede\u64ca\u300c\u662f\u300d\u4ee5\u7e7c\u7e8c\u6e05\u7406\u3002\n\u9ede\u64ca\u300c\u5426\u300d\u4ee5\u7a0d\u5f8c\u57f7\u884c\uff08\u61c9\u7528\u7a0b\u5f0f\u5c07\u5728\u4e0b\u6b21\u555f\u52d5\u6642\u518d\u6b21\u8a62\u554f\uff09\u3002",
  "dialog.cleanup_complete_title": "\u6e05\u7406\u5b8c\u6210",
  "dialog.cleanup_complete_body": "\u539f\u7248\u5099\u4efd\u5df2\u91cd\u8a2d\u3002\n\n\u60a8\u7684\u6a21\u7d44\u4ecd\u5728\u6e05\u55ae\u4e2d\uff0c\u4f46\u5df2\u505c\u7528\u3002\n\u555f\u7528\u5b83\u5011\u4e26\u9ede\u64ca\u300c\u5957\u7528\u300d\u4ee5\u6b63\u78ba\u91cd\u5efa\u4e00\u5207\u3002",
  "dialog.game_update_detected_title": "\u5075\u6e2c\u5230\u904a\u6232\u66f4\u65b0",
  "dialog.game_update_detected_body": "Crimson Desert \u5df2\u66f4\u65b0{build_info}\u3002\n\n\u61c9\u7528\u7a0b\u5f0f\u5c07\u91cd\u8a2d\u4e26\u91cd\u65b0\u6383\u63cf\u60a8\u7684\u904a\u6232\u6a94\u6848\u3002\u4e4b\u5f8c\u53ea\u9700\u91cd\u65b0\u532f\u5165\u60a8\u7684\u6a21\u7d44\u5373\u53ef\u3002\n\n\u8acb\u6ce8\u610f\uff1a\u904a\u6232\u66f4\u65b0\uff08\u5305\u542b\u71b1\u4fee\u5fa9\uff09\u53ef\u80fd\u6703\u5c0e\u81f4\u6a21\u7d44\u5931\u6548\u3002\u5982\u679c\u6a21\u7d44\u505c\u6b62\u904b\u4f5c\uff0c\u53ef\u80fd\u9700\u8981\u7531\u4f5c\u8005\u91dd\u5c0d\u65b0\u904a\u6232\u7248\u672c\u9032\u884c\u66f4\u65b0\u3002",
  "dialog.mods_need_reimport_old_title": "\u6a21\u7d44\u9700\u8981\u91cd\u65b0\u532f\u5165",
  "dialog.mods_need_reimport_old_body": "\u4ee5\u4e0b\u6a21\u7d44\u662f\u7531\u820a\u7248\u672c\u532f\u5165\u7684\uff0c\u53ef\u80fd\u6703\u5c0e\u81f4\u904a\u6232\u7576\u6a5f\uff1a\n\n{names}\n\n\u5b83\u5011\u9700\u8981\u89e3\u9664\u5b89\u88dd\u4e26\u91cd\u65b0\u532f\u5165\u624d\u80fd\u6b63\u5e38\u904b\u4f5c\u3002\n\n\u73fe\u5728\u89e3\u9664\u5b89\u88dd\uff1f",
  "dialog.cleanup_complete_removed_title": "\u6e05\u7406\u5b8c\u6210",
  "dialog.cleanup_complete_removed_body": "\u5df2\u79fb\u9664 {count} \u500b\u6709\u554f\u984c\u7684\u6a21\u7d44\uff1a\n{names}\n\n\u6240\u6709\u6a21\u7d44\u5df2\u505c\u7528\u3002\u91cd\u65b0\u555f\u7528\u60a8\u7684\u6a21\u7d44\uff0c\u9ede\u64ca\u300c\u5957\u7528\u300d\uff0c\u7136\u5f8c\u91cd\u65b0\u532f\u5165\u5df2\u79fb\u9664\u7684\u6a21\u7d44\u3002",
  "dialog.first_run_title": "\u9996\u6b21\u57f7\u884c \u2014 \u5efa\u7acb\u5feb\u7167",
  "dialog.first_run_body": "\u5c1a\u672a\u5efa\u7acb\u539f\u7248\u5feb\u7167\u3002\u5728\u532f\u5165\u6a21\u7d44\u4e4b\u524d\u9700\u8981\u5feb\u7167\u3002\n\n\u9019\u5c07\u6383\u63cf\u6240\u6709\u904a\u6232\u6a94\u6848\uff0c\u53ef\u80fd\u9700\u8981\u5e7e\u5206\u9418\u3002\n\n\u73fe\u5728\u5efa\u7acb\u5feb\u7167\uff1f",
  "dialog.mod_already_installed_title": "\u6a21\u7d44\u5df2\u5b89\u88dd",
  "dialog.mod_already_installed_body": "\u300c{name}\u300d\u5df2\u5b89\u88dd\u3002\n\n\u8981\u7528\u65b0\u7248\u672c\u66f4\u65b0\u5b83\u55ce\uff1f",
  "dialog.choose_variant_title": "\u9078\u64c7\u8b8a\u9ad4",
  "dialog.choose_variant_body": "\u6b64\u6a21\u7d44\u6709 {count} \u500b\u8b8a\u9ad4\u3002\n\u9078\u64c7\u8981\u5b89\u88dd\u54ea\u500b\uff1a",
  "dialog.script_mod_name_title": "\u8173\u672c\u6a21\u7d44\u540d\u7a31",
  "dialog.script_mod_name_body": "\u8acb\u8f38\u5165\u6b64\u6a21\u7d44\u7684\u540d\u7a31\uff1a",
  "dialog.rename_mod_title": "\u91cd\u65b0\u547d\u540d\u6a21\u7d44",
  "dialog.rename_mod_body": "\u65b0\u540d\u7a31\uff1a",
  "dialog.revert_title": "\u9084\u539f\u81f3\u539f\u7248",
  "dialog.revert_body": "\u9019\u5c07\u6062\u5fa9\u6240\u6709\u904a\u6232\u6a94\u6848\u81f3\u539f\u59cb\u72c0\u614b\u3002\n\u6240\u6709\u5df2\u5957\u7528\u7684\u6a21\u7d44\u8b8a\u66f4\u5c07\u88ab\u79fb\u9664\u3002\n\n\u7e7c\u7e8c\uff1f",
  "dialog.revert_incomplete_title": "\u9084\u539f\u4e0d\u5b8c\u6574",
  "dialog.uninstall_title": "\u89e3\u9664\u5b89\u88dd\u6a21\u7d44",
  "dialog.uninstall_single_body": "\u89e3\u9664\u5b89\u88dd\u300c{name}\u300d\uff1f",
  "dialog.uninstall_multi_body": "\u89e3\u9664\u5b89\u88dd {count} \u500b\u6a21\u7d44\uff1f\n\n{names}",
  "dialog.mod_name_mismatch_title": "\u6a21\u7d44\u540d\u7a31\u4e0d\u7b26",
  "dialog.mod_name_mismatch_body": "\u62d6\u653e\u7684\u6a21\u7d44\u662f\u300c{dropped_name}\u300d\uff0c\u4f46\u60a8\u6b63\u5728\u66f4\u65b0\u300c{existing_name}\u300d\u3002\n\n\u78ba\u5b9a\u9019\u662f\u6b63\u78ba\u7684\u6a21\u7d44\u55ce\uff1f",
  "dialog.rescan_title": "\u91cd\u65b0\u6383\u63cf\u904a\u6232\u6a94\u6848",
  "dialog.rescan_body": "\u9019\u5c07\u5f9e\u60a8\u76ee\u524d\u7684\u904a\u6232\u6a94\u6848\u5efa\u7acb\u65b0\u7684\u539f\u7248\u5feb\u7167\u3002\n\n\u60a8\u5df2\u900f\u904e Steam \u9a57\u8b49\u904a\u6232\u6a94\u6848\u4e86\u55ce\uff1f\n\n  Steam \u2192 \u53f3\u9375\u9ede\u64ca Crimson Desert \u2192 \u5167\u5bb9\n  \u2192 \u5df2\u5b89\u88dd\u7684\u6a94\u6848 \u2192 \u9a57\u8b49\u904a\u6232\u6a94\u6848\u7684\u5b8c\u6574\u6027\n\n\u53ea\u6709\u5728 Steam \u9a57\u8b49\u5f8c\u624d\u9032\u884c\u91cd\u65b0\u6383\u63cf \u2014 \u5426\u5247\u5feb\u7167\n\u53ef\u80fd\u6703\u5c07\u5df2\u4fee\u6539\u7684\u6a94\u6848\u8996\u70ba\u300c\u539f\u7248\u300d\u3002",
  "dialog.game_is_running_title": "\u904a\u6232\u57f7\u884c\u4e2d",
