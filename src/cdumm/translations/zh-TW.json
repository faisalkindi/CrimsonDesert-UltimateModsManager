  "dialog.mod_check_title": "\u6a21\u7d44\u6aa2\u67e5",
  "dialog.mod_check_no_issues": "\u672a\u767c\u73fe\u554f\u984c\u3002\u6240\u6709\u6a21\u7d44\u72c0\u614b\u826f\u597d\u3002",
  "dialog.mod_check_issues": "\u767c\u73fe {count} \u500b\u554f\u984c\uff1a\n\n{issues}\n\n\u505c\u7528 {broken_count} \u500b\u6709\u554f\u984c\u7684\u6a21\u7d44\uff1f",
  "dialog.mod_check_issues_no_action": "\u767c\u73fe {count} \u500b\u554f\u984c\uff1a\n\n{issues}",
