  "dialog.post_apply_verify_title": "\u5957\u7528\u5f8c\u9a57\u8b49",
  "dialog.post_apply_verify_body": "\u767c\u73fe {count} \u500b\u53ef\u80fd\u5c0e\u81f4\u904a\u6232\u7576\u6a5f\u7684\u554f\u984c\uff1a\n\n{issues}\n\n\u62ec\u865f\u5167\u7684\u6a21\u7d44\u540d\u7a31\u8868\u793a\u53ef\u80fd\u7684\u539f\u56e0\u3002",
  "dialog.leftover_backups_title": "\u767c\u73fe\u6b98\u7559\u5099\u4efd\u6a94\u6848",
  "dialog.leftover_backups_body": "\u5728\u904a\u6232\u76ee\u9304\u4e2d\u767c\u73fe {count} \u500b\u5099\u4efd\u6a94\u6848\uff08{size_mb} MB\uff09\uff1a\n\n{names}\n\n\u9019\u4e9b\u662f\u7531\u500b\u5225\u6a21\u7d44\u8173\u672c\u5efa\u7acb\u7684\uff08\u4e0d\u662f CDUMM\uff09\u3002\nCDUMM \u6709\u81ea\u5df1\u7684\u5099\u4efd\u7cfb\u7d71\uff0c\u4e0d\u4f7f\u7528\u9019\u4e9b\u6a94\u6848\u3002\n\u5b83\u5011\u53ea\u662f\u4f54\u7528\u78c1\u789f\u7a7a\u9593\u3002\n\n\u522a\u9664\uff1f",
  "dialog.error_title": "\u932f\u8aa4",
  "dialog.some_imports_failed_title": "\u90e8\u5206\u532f\u5165\u5931\u6557",
  "dialog.some_imports_failed_body": "{count} \u500b\u6a21\u7d44\u6709\u554f\u984c\uff1a\n\n{errors}",
  "dialog.some_imports_failed_full_body": "{count} \u500b\u6a21\u7d44\u532f\u5165\u5931\u6557\uff1a\n\n{errors}\n\n\u5176\u4ed6\u6a21\u7d44\u5df2\u6210\u529f\u532f\u5165\u3002",
  "dialog.cannot_configure_title": "\u7121\u6cd5\u8a2d\u5b9a",
  "dialog.cannot_configure_no_source": "\u627e\u4e0d\u5230\u6a21\u7d44\u4f86\u6e90\u6a94\u6848\u3002",
  "dialog.cannot_configure_file_missing": "\u627e\u4e0d\u5230\u539f\u59cb\u6a94\u6848\uff1a\n{path}\n\n\u8acb\u91cd\u65b0\u62d6\u653e\u6a21\u7d44\u6a94\u6848\u4ee5\u4f7f\u7528\u65b0\u8a2d\u5b9a\u91cd\u65b0\u532f\u5165\u3002",
  "dialog.cannot_configure_no_options": "\u5728\u6b64\u6a21\u7d44\u4e2d\u627e\u4e0d\u5230\u53ef\u8a2d\u5b9a\u7684\u9078\u9805\u3002",
  "dialog.invalid_directory_title": "\u7121\u6548\u76ee\u9304",
  "dialog.invalid_directory_body": "\u9019\u4e0d\u50cf\u662f Crimson Desert \u7684\u5b89\u88dd\u76ee\u9304\u3002\n\u9810\u671f\u5728\u6240\u9078\u8cc7\u6599\u593e\u4e2d\u627e\u5230 meta/0.papgt\u3002",
  "dialog.game_dir_changed_title": "\u904a\u6232\u76ee\u9304\u5df2\u8b8a\u66f4",
  "dialog.game_dir_changed_body": "\u904a\u6232\u76ee\u9304\u5df2\u8a2d\u5b9a\u70ba\uff1a\n{path}\n\n\u60a8\u61c9\u9ede\u64ca\u300c\u91cd\u65b0\u6574\u7406\u5feb\u7167\u300d\u4ee5\u7d22\u5f15\u65b0\u7684\u5b89\u88dd\u3002",
