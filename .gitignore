__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
# Keep cdmm.spec tracked (needed for builds)
!cdmm.spec
.eggs/
*.egg
.venv/
venv/
.pytest_cache/
.ruff_cache/
# Rust native module build artifacts
native/target/
*.pyd
*.pdb
# Vendored Rust extensions (third-party, MPL-2.0) ARE tracked despite
# the *.pyd rule above so PyInstaller can bundle them on fresh checkouts.
!src/cdumm/_vendor/**/*.pyd

# External test fixtures: third-party mod files downloaded for the
# format3 / dropset / iteminfo / skill writer tests. Tests skip when
# absent so it's safe to leave these uncommitted.
tests/_test_mods_external/

# Claude Code project-local permission file
.claude/

# Local investigation scratch
.tmp_*
reviewcode_diff.patch

# macOS
.DS_Store
# macOS build artifacts. cdumm.icns is regenerated from
# assets/cdumm-logo.png by scripts/build-macos.sh on every build.
cdumm.icns